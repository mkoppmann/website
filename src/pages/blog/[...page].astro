---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import type { GetStaticPathsOptions, Page } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import JsonLd from "../../components/JsonLd.astro";
import Pagination from "../../components/Pagination.astro";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const sorted = posts.sort(
    (a, b) => b.data.createdDate.valueOf() - a.data.createdDate.valueOf(),
  );
  return paginate(sorted, { pageSize: 10 });
}

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const blogDescription = "My thoughts and understandings on our world.";
const collectionPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Blog",
  description: blogDescription,
  url: canonicalURL,
};

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<BaseLayout title="Blog" description={blogDescription}>
  <Fragment slot="head">
    <JsonLd schema={collectionPageJsonLd} />
  </Fragment>

  <h1 slot="pageHeader">Blog</h1>
  <p class="subtitle" slot="pageHeader">
    {blogDescription}
  </p>

  <main id="main-content">
    <section>
      <h2>All posts</h2>
      {
        page.data.length === 0 ? (
          <p>No posts yet. Check back soon!</p>
        ) : (
          <ol class="post-list">
            {page.data.map((post) => {
              return (
                <li class="post-card">
                  <div class="post-date">
                    <time
                      datetime={post.data.createdDate
                        .toISOString()
                        .slice(0, 10)}
                    >
                      {formatDate(post.data.createdDate)}
                    </time>
                  </div>
                  <h3 class="post-title">
                    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                  </h3>
                  <p class="post-description">{post.data.description}</p>
                </li>
              );
            })}
          </ol>
        )
      }
    </section>

    <Pagination
      prevUrl={page.url.prev}
      nextUrl={page.url.next}
      currentPage={page.currentPage}
      lastPage={page.lastPage}
    />
  </main>
</BaseLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0 0;
  }

  .post-card {
    margin: 0 0 var(--space-sm);
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-page-bg);
  }

  .post-card:last-child {
    margin-block-end: 0;
  }

  .post-date {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-caption);
    margin-block-end: var(--space-2xs);
  }

  .post-title {
    margin: var(--space-2xs) 0 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.28;
  }

  .post-description {
    margin: var(--space-2xs) 0 0;
    font-size: 0.9rem;
    line-height: var(--line-height-body);
    color: var(--color-text);
    opacity: 0.8;
    max-width: 60ch;
  }
</style>
