---
import StructuredEntriesList from "../components/StructuredEntriesList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { talks } from "../data/talks";

const title = "Talks";
const description = "Talks and tutorials by Michael Koppmann.";

const sortedTalks = [...talks].sort((left, right) =>
  right.date.localeCompare(left.date),
);
---

<BaseLayout title={title} description={description}>
  <h1 slot="pageHeader">Talks</h1>

  <main id="main-content" data-pagefind-body>
    <section>
      <h2>All talks</h2>
      <p>Public talks, tutorials, and recorded sessions.</p>
      <StructuredEntriesList items={sortedTalks} />
    </section>
  </main>
</BaseLayout>
