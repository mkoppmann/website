---
import BaseLayout from "../layouts/BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";

const title = "Contact";
const description = "Contact details for www.mkoppmann.at.";
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const contactPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: title,
  description,
  url: canonicalURL,
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <JsonLd schema={contactPageJsonLd} />
  </Fragment>

  <h1 slot="pageHeader">Contact</h1>

  <main id="main-content" data-pagefind-body>
    <section>
      <h2>Get in touch</h2>
      <p>You can reach me via the following channels:</p>
      <ul>
        <li>
          E-mail: <a href="mailto:me+www@mkoppmann.at">me+www@mkoppmann.at</a>
        </li>
        <li>
          Signal: <a
            href="https://signal.me/#eu/c-kNDWlbDpdATY1glAtZPP3-mWWON3doCJV5qDhU5Hh8V7CXWLxNYZOwb-Yb8YVy"
            >mkoppmann.04</a
          >
        </li>
        <li>
          Matrix: <a href="https://matrix.to/#/@shibayashi:ncrypt.at"
            >@shibayashi:ncrypt.at</a
          >
        </li>
      </ul>
    </section>
  </main>
</BaseLayout>
