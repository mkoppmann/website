---
import BaseLayout from "../layouts/BaseLayout.astro";
import JsonLd from "../components/JsonLd.astro";
import StructuredEntriesList from "../components/StructuredEntriesList.astro";
import { getCollection } from "astro:content";
import Figure from "../components/Figure.astro";
import SpeakerImage from "../assets/devsec2025_speaker.jpg";

const title = "Home of Michael Koppmann";
const description =
  "@mkoppmann's mneme – Home of Michael Koppmann, a security consultant, writer, and speaker. Trying to make everything a tiny bit better.";

const allPublications = await getCollection("publications");
const latestFourPublications = allPublications
  .sort((left, right) => right.data.date.localeCompare(left.data.date))
  .slice(0, 4)
  .map((pub) => ({ ...pub.data, href: `/publications/${pub.id}/` }));
const allTalks = await getCollection("talks");
const latestFourTalks = allTalks
  .sort((left, right) => right.data.date.localeCompare(left.data.date))
  .slice(0, 4)
  .map((talk) => ({ ...talk.data, href: `/talks/${talk.id}/` }));

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const profilePageJsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  name: title,
  description,
  url: canonicalURL,
  mainEntity: {
    "@type": "Person",
    name: "Michael Koppmann",
    jobTitle: "Information Security Consultant",
    worksFor: {
      "@type": "Organization",
      name: "SBA Research",
      url: "https://www.sba-research.org",
    },
    alumniOf: {
      "@type": "CollegeOrUniversity",
      name: "TU Wien",
      url: "https://www.tuwien.at/",
    },
    url: Astro.site?.href,
    sameAs: [
      "https://github.com/mkoppmann",
      "https://www.sba-research.org/team/michael-koppmann/",
      "https://orcid.org/0000-0001-5699-8226",
      "https://communicating.cypherpunk.observer/shibayashi",
    ],
  },
};
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <JsonLd schema={profilePageJsonLd} />
  </Fragment>

  <h1 slot="pageHeader">Security Consultant, Writer, Speaker</h1>

  <main id="main-content" data-pagefind-body>
    <section id="about-me">
      <h2>About me</h2>
      <p>
        I am Michael Koppmann, an Information Security Consultant at <a
          href="https://www.sba-research.org">SBA Research</a
        >. My mission is to make the world a tiny bit better by promoting
        systems and patterns that are inherently resilient and less error-prone.
        I hold a master’s degree in “Software Engineering and Internet
        Computing” from <a href="https://www.tuwien.at/">TU Wien</a>.
      </p>
      <Figure
        src={SpeakerImage}
        alt="Me speaking at Heise devSec 2025. I’m holding a microphone and looking at the audience."
        caption="© dpunkt.verlag"
      />
      <p>
        My core interests include secure and sustainable software engineering,
        functional programming, privacy-enhancing technologies, and open source.
        Beyond code, I care deeply about environmental protection, health and
        fitness, human rights, and continuous self-improvement.
      </p>
    </section>
    <section id="certifications">
      <h2>Certifications</h2>
      <ul>
        <li>
          Offensive Security Certified Professional (<a
            href="https://www.offensive-security.com/pwk-oscp/">OSCP</a
          >)
        </li>
        <li>
          Certified Information Systems Security Professional (<a
            href="https://www.isc2.org/Certifications/CISSP">CISSP</a
          >)
        </li>
        <li>
          Certified Secure Software Lifecycle Professional (<a
            href="https://www.isc2.org/Certifications/CSSLP">CSSLP</a
          >)
        </li>
        <li>
          GIAC Web Application Penetration Tester (<a
            href="https://www.giac.org/certifications/web-application-penetration-tester-gwapt/"
            >GWAPT</a
          >)
        </li>
      </ul>
    </section>
    <section id="affiliations">
      <h2>Affiliations</h2>
      <ul>
        <li>
          Chapter leader of <a href="https://owasp.org/www-chapter-vienna/"
            >OWASP Vienna Chapter</a
          >
        </li>
        <li>
          Member of <a href="https://owasp.org">OWASP</a>
        </li>
        <li>
          Member of <a href="https://c3w.at">Chaos Computer Club Wien</a>
        </li>
        <li>
          Member of <a href="https://applied-privacy.net">Applied Privacy</a>
        </li>
      </ul>
    </section>
    <section id="recent-publications-and-talks">
      <h2>Recent publications and talks</h2>
      <p>
        Here are my recent publications and public talks. Visit the <a
          href="/publications/">publications</a
        > and <a href="/talks/">talks</a> pages for more.
      </p>
      <h3>Publications</h3>
      <StructuredEntriesList items={latestFourPublications} />
      <h3>Talks</h3>
      <StructuredEntriesList items={latestFourTalks} />
    </section>
    <section id="for-verification">
      <h2>For verification</h2>
      <p>You can verify my identity with these services:</p>
      <ul>
        <li>
          <a rel="me" href="https://github.com/mkoppmann">GitHub</a>
        </li>
        <li>
          <a rel="me" href="https://www.sba-research.org/team/michael-koppmann/"
            >SBA Research</a
          >
        </li>
        <li>
          <a rel="me" href="https://orcid.org/0000-0001-5699-8226">ORCID ID</a>
        </li>
        <li>
          <a
            rel="me"
            href="https://communicating.cypherpunk.observer/shibayashi"
            >Fediverse</a
          >
        </li>
      </ul>
      <p>
        My <abbr title="Pretty Good Privacy">PGP</abbr> fingerprint: <code
          >E9B3 3326 8618 0E5E 498C 6C97 63CA B0C7 75EB 9C80</code
        >
      </p>
      <p>
        My Signal “safety numbers”: <code
          >88630 72114 80083 44420 49604 09486</code
        >
      </p>
      <p>
        The <a href="/contact/">contact</a> page lists ways to reach me.
      </p>
    </section>
  </main>
</BaseLayout>
