---
import StructuredEntriesList from "../components/StructuredEntriesList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { publications } from "../data/publications";

const title = "Publications";
const description = "Publications by Michael Koppmann.";

const sortedPublications = [...publications].sort((left, right) =>
  right.date.localeCompare(left.date),
);
---

<BaseLayout title={title} description={description}>
  <h1 slot="pageHeader">Publications</h1>

  <main id="main-content" data-pagefind-body>
    <section>
      <h2>All publications</h2>
      <p>Articles, papers, and other written publications.</p>
      <StructuredEntriesList items={sortedPublications} />
    </section>
  </main>
</BaseLayout>
