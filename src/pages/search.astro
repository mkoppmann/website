---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Search";
const description = "Search across pages on www.mkoppmann.at.";
---

<BaseLayout title={title} description={description}>
  <h1 slot="pageHeader">Search</h1>

  <Fragment slot="head">
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <script type="module" src="/scripts/pagefind-init.js" is:inline></script>
  </Fragment>

  <main id="main-content" data-pagefind-ignore>
    <section class="search-section">
      <p class="search-intro">Find content across this website.</p>
      <div id="search" class="search-root" aria-label="Website search"></div>
    </section>
  </main>
</BaseLayout>

<style>
  .search-root {
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-primary: var(--color-link);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-page-bg);
  }

  .search-root :global(.pagefind-ui__search-input::placeholder) {
    color: var(--color-text);
    opacity: 0.65;
  }
</style>
