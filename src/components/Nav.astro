---
const currentPath = Astro.url.pathname;
const siteName = "@mkoppmann’s mneme";
---

<nav>
  <a href="/" class="nav-brand">{siteName}</a>
  <div class="nav-links">
    <a href="/" class:list={[{ active: currentPath === "/" }]}>Home</a>
    <a href="/contact/" class:list={[{ active: currentPath === "/contact/" }]}
      >Contact</a
    >
    <a
      href="/search/"
      class="nav-search"
      class:list={[{ active: currentPath === "/search/" }]}
      aria-label="Search"
      title="Search"
    >
      <svg viewBox="0 0 24 24" role="img" aria-hidden="true">
        <path
          d="M11 3a8 8 0 1 0 4.9 14.33l4.88 4.88a1 1 0 0 0 1.42-1.42l-4.88-4.88A8 8 0 0 0 11 3zm0 2a6 6 0 1 1 0 12 6 6 0 0 1 0-12z"
          fill="currentColor"></path>
      </svg>
    </a>
  </div>

  <style>
    nav {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: var(--space-lg) 0;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: var(--space-md);
    }

    .nav-brand {
      font-size: 0.875rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      text-decoration: none;
      color: var(--color-heading);
    }

    .nav-links {
      display: flex;
      gap: var(--space-lg);
    }

    :where(.nav-links a) {
      display: inline-block;
      font-size: 0.8125rem;
      text-decoration: none;
      padding-bottom: var(--space-2xs);
      background-image: linear-gradient(currentColor, currentColor);
      background-repeat: no-repeat;
      background-position: 0 100%;
      background-size: 0 2px;
      transition: background-size 180ms ease;
    }

    :where(.nav-links a:hover),
    :where(.nav-links a.active) {
      background-size: 100% 2px;
    }

    :where(.nav-links a:focus-visible) {
      background-size: 100% 2px;
    }

    :where(.nav-links a:focus:not(:focus-visible)) {
      background-size: 0 2px;
    }

    .nav-search {
      padding-inline: var(--space-2xs);
    }

    .nav-search svg {
      display: block;
      width: 0.9em;
      height: 0.9em;
      transform: translateY(0.08em);
      pointer-events: none;
    }

    @media (max-width: 480px) {
      nav {
        flex-direction: column;
        align-items: flex-start;
        padding: var(--space-md) 0;
        gap: var(--space-sm);
      }

      .nav-brand {
        margin-bottom: var(--space-2xs);
      }

      .nav-links {
        gap: var(--space-md);
      }
    }

    @media (max-width: 320px) {
      nav {
        padding: var(--space-sm) 0;
        gap: var(--space-xs);
      }

      .nav-brand {
        font-size: 0.75rem;
        margin-bottom: var(--space-2xs);
      }

      .nav-links {
        gap: var(--space-sm);
      }

      .nav-links a {
        font-size: 0.7rem;
      }
    }
  </style>
</nav>
