---
import { Image, Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  sizes?: string;
  maxWidth?: number | `${number}px`;
}

const {
  src,
  alt,
  caption,
  sizes = "(min-width: 58rem) 38rem, (min-width: 40rem) calc(100vw - 6rem), calc(100vw - 2rem)",
  maxWidth,
} = Astro.props;

const maxWidthPx =
  typeof maxWidth === "number"
    ? maxWidth
    : maxWidth
      ? Number.parseFloat(maxWidth)
      : undefined;

const isVector = src.format === "svg";
const targetMaxWidth = maxWidthPx
  ? Math.min(Math.floor(maxWidthPx), src.width)
  : undefined;

const computedWidths = isVector
  ? undefined
  : [480, 720, 960, 1200]
      .filter((width) => width < (targetMaxWidth ?? src.width))
      .concat(targetMaxWidth ?? src.width)
      .filter((width, index, widths) => widths.indexOf(width) === index);
---

<figure>
  {
    isVector ? (
      <Image src={src} alt={alt} width={targetMaxWidth} />
    ) : (
      <Picture
        src={src}
        alt={alt}
        formats={["avif", "webp"]}
        sizes={sizes}
        widths={computedWidths}
        width={targetMaxWidth}
      />
    )
  }
  {caption && <figcaption set:html={caption} />}
</figure>

<style>
  figure {
    margin-inline: auto;
  }
</style>
