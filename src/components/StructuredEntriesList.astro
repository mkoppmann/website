---
interface EntryLink {
  label: string;
  href: string;
}

export interface StructuredEntry {
  title: string;
  type: string;
  venue: string;
  date: string;
  language: string;
  links: EntryLink[];
}

interface Props {
  items: StructuredEntry[];
}

const { items } = Astro.props;

function formatDate(value: string): string {
  const fullDateMatch = /^(\d{4}-\d{2})-\d{2}$/.exec(value);
  return fullDateMatch ? fullDateMatch[1] : value;
}
---

<ul class="entries-cards" role="list">
  {
    items.map((item) => (
      <li>
        <article class="entry-card">
          <h3 class="entry-title">{item.title}</h3>
          <p class="entry-venue">
            <em>{item.venue}</em>
          </p>
          <div class="entry-meta">
            <span class="entry-type">{item.type}</span>
            <time class="entry-date" datetime={item.date}>
              {formatDate(item.date)}
            </time>
            <span class="entry-language">{item.language}</span>
          </div>
          <ul
            class="entry-links"
            role="list"
            aria-label={`Links for ${item.title}`}
          >
            {item.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </article>
      </li>
    ))
  }
</ul>

<style>
  .entries-cards {
    display: grid;
    gap: var(--space-sm);
    margin: var(--space-sm) 0 0;
    padding: 0;
    list-style: none;
  }

  .entries-cards > li {
    margin: 0;
  }

  .entry-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-page-bg);
    padding: 0.8rem;
  }

  .entry-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.28;
  }

  .entry-venue {
    margin: 0.3rem 0 0;
    font-size: 0.9rem;
    font-style: italic;
  }

  .entry-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin: 0.4rem 0 0;
    font-size: 0.8rem;
  }

  .entry-type,
  .entry-date,
  .entry-language {
    display: inline-block;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.05rem 0.45rem;
    font-size: 0.76rem;
    line-height: 1.3;
    background-color: var(--color-surface);
  }

  .entry-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0.45rem 0 0;
    padding: 0;
    list-style: none;
  }

  .entry-links li {
    margin: 0;
  }

  .entry-links a {
    display: inline-block;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.08rem 0.45rem;
    text-decoration: none;
    font-size: 0.8rem;
    background-color: var(--color-surface);
  }

  .entry-links a:hover {
    text-decoration: underline;
  }

  @media (min-width: 52rem) {
    .entries-cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-md);
    }
  }
</style>
